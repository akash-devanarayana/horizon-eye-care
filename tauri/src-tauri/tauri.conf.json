{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Horizon",
  "version": "0.1.0",
  "identifier": "com.horizon.eyecare",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Horizon (spike)",
        "width": 520,
        "height": 420
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "transparent": true,
        "decorations": false,
        "fullscreen": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
